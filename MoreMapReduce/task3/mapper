#!/usr/bin/env python3
import sys

for line in sys.stdin:
    parts = line.strip().split()
    if len(parts) >= 3:
        time_str = parts[1]
        severity = parts[2]
        time_parts = time_str.split(':')
        if len(time_parts) >= 2:
            try:
                # Extract minute and strip leading zeros by converting to int
                minute_val = int(time_parts[1])
                print(f"{minute_val}\t{severity}")
            except ValueError:
                pass
